						"url": "{{baseUrl}}/api/users/me",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
					},
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"pm.test('Profile retrieved', function() {",
								"  pm.expect(pm.response.code).to.eql(200);",
								"  var json = pm.response.json();",
								"  pm.expect(json.email).to.not.be.empty;",
								"});"
							]
						}
					}]
				},
				{
					"name": "2.2 Update My Profile",
					"request": {
						"method": "PUT",
						"url": "{{baseUrl}}/api/users/me",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fullName\": \"Updated Customer Name\",\n  \"phone\": \"+94779998877\"\n}"
						}
					},
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"pm.test('Profile updated', function() {",
								"  pm.expect(pm.response.code).to.eql(200);",
								"  pm.expect(pm.response.json().fullName).to.eql('Updated Customer Name');",
								"});"
							]
						}
					}]
				}
			]
		},
		{
			"name": "3. MOVIES (Public)",
			"item": [
				{
