{
	"info": {
		"name": "Cinema Seat Management API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"description": "Complete API test suite — import and run the 'Full Flow' folder top to bottom"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "accessToken", "value": "" },
		{ "key": "refreshToken", "value": "" },
		{ "key": "adminToken", "value": "" },
		{ "key": "userId", "value": "" },
		{ "key": "movieId", "value": "" },
		{ "key": "showtimeId", "value": "" },
		{ "key": "bookingId", "value": "" },
		{ "key": "bookingCode", "value": "" },
		{ "key": "seatId1", "value": "" },
		{ "key": "seatId2", "value": "" },
		{ "key": "kioskApiKey", "value": "KIOSK-HALL-A-2026-DEMO-KEY" }
	],
	"item": [
		{
			"name": "1. AUTH",
			"item": [
				{
					"name": "1.1 Register Customer",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/auth/register",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"newcustomer@test.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"New Customer\",\n  \"phone\": \"+94771112233\"\n}"
						}
					},
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"if (pm.response.code === 201) {",
								"  var json = pm.response.json();",
								"  pm.collectionVariables.set('accessToken', json.accessToken);",
								"  pm.collectionVariables.set('refreshToken', json.refreshToken);",
								"  pm.collectionVariables.set('userId', json.userId);",
								"  pm.test('Register success — token received', function() {",
								"    pm.expect(json.accessToken).to.not.be.empty;",
								"    pm.expect(json.role).to.eql('CUSTOMER');",
								"  });",
								"}"
							]
						}
					}]
				},
				{
					"name": "1.2 Login as Admin",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/auth/login",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@cinema.com\",\n  \"password\": \"admin123\"\n}"
						}
					},
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"if (pm.response.code === 200) {",
								"  var json = pm.response.json();",
								"  pm.collectionVariables.set('adminToken', json.accessToken);",
								"  pm.test('Admin login success', function() {",
								"    pm.expect(json.role).to.eql('ADMIN');",
								"  });",
								"}"
							]
						}
					}]
				},
				{
					"name": "1.3 Login as Customer",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/auth/login",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"customer@test.com\",\n  \"password\": \"customer123\"\n}"
						}
					},
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"if (pm.response.code === 200) {",
								"  var json = pm.response.json();",
								"  pm.collectionVariables.set('accessToken', json.accessToken);",
								"  pm.collectionVariables.set('refreshToken', json.refreshToken);",
								"  pm.collectionVariables.set('userId', json.userId);",
								"  pm.test('Customer login success', function() {",
								"    pm.expect(json.role).to.eql('CUSTOMER');",
								"  });",
								"}"
							]
						}
					}]
				},
				{
					"name": "1.4 Refresh Token",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/auth/refresh",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
						}
					},
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"if (pm.response.code === 200) {",
								"  var json = pm.response.json();",
								"  pm.collectionVariables.set('accessToken', json.accessToken);",
								"  pm.collectionVariables.set('refreshToken', json.refreshToken);",
								"  pm.test('Token refreshed', function() {",
								"    pm.expect(json.accessToken).to.not.be.empty;",
								"  });",
								"}"
							]
						}
					}]
				},
				{
					"name": "1.5 Logout",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/auth/logout",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
						}
					},
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"pm.test('Logout success — 204', function() {",
								"  pm.expect(pm.response.code).to.eql(204);",
								"});"
							]
						}
					}]
				}
			]
		},
		{
