								"  pm.expect(pm.response.code).to.eql(200);",
								"  var json = pm.response.json();",
								"  pm.expect(json.seats.length).to.be.above(0);",
								"  pm.collectionVariables.set('seatId1', json.seats[0].seatId);",
								"  pm.collectionVariables.set('seatId2', json.seats[1].seatId);",
								"});"
							]
						}
					}]
				}
			]
		},
		{
			"name": "6. BOOKING (Customer)",
			"item": [
				{
					"name": "6.1 Create Booking (2 seats)",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/bookings",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"showtimeId\": {{showtimeId}},\n  \"seatIds\": [{{seatId1}}, {{seatId2}}],\n  \"paymentMethod\": \"CARD\"\n}"
						}
					},
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"if (pm.response.code === 201) {",
								"  var json = pm.response.json();",
								"  pm.collectionVariables.set('bookingId', json.id);",
								"  pm.collectionVariables.set('bookingCode', json.bookingCode);",
								"  pm.test('Booking created', function() {",
								"    pm.expect(json.bookingCode).to.not.be.empty;",
								"    pm.expect(json.seats.length).to.eql(2);",
								"  });",
								"}"
							]
